class Solution:
    def findIndex(self, arr, key):
        b = []
        
        # 1. Loop through the entire array and collect all matching indices
        for i in range(len(arr)):
            if arr[i] == key:
                b.append(i)
                
        # 2. After the loop is completely done, check if the key was ever found
        if len(b) == 0:
            return [-1, -1]
            
        # 3. Return the first index (b[0]) and the last index (b[-1])
        return [b[0], b[-1]]
